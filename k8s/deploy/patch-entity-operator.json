{
  "spec": {
    "template": {
      "spec": {
        "containers": [
          {
            "name": "topic-operator",
            "livenessProbe": {
              "initialDelaySeconds": 90,
              "timeoutSeconds": 10,
              "periodSeconds": 15,
              "failureThreshold": 6
            },
            "readinessProbe": {
              "initialDelaySeconds": 90,
              "timeoutSeconds": 10,
              "periodSeconds": 15,
              "failureThreshold": 6
            }
          },
          {
            "name": "user-operator",
            "livenessProbe": {
              "initialDelaySeconds": 90,
              "timeoutSeconds": 10,
              "periodSeconds": 15,
              "failureThreshold": 6
            },
            "readinessProbe": {
              "initialDelaySeconds": 90,
              "timeoutSeconds": 10,
              "periodSeconds": 15,
              "failureThreshold": 6
            }
          }
        ]
      }
    }
  }
}
